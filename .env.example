# Root-level environment variables for Docker Compose orchestration.
# Copy to .env and fill in values before running any `docker compose` command.
#
# App/service-specific config lives in:
#   server/.env.*        — FastAPI config (DB, Clerk, LLM, rate limits, …)
#   web-app/.env.local   — Next.js config (NEXT_PUBLIC_* build args, Clerk keys, …)

# Controls which server env file docker-compose.yml loads
# (./server/.env.${APP_ENV:-development})
APP_ENV=development

# Grafana admin password — required by docker-compose.yml (monitoring stack)
GRAFANA_ADMIN_PASSWORD=change-me
