{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Debug API Server",
      "type": "debugpy",
      "request": "launch",
      "console": "integratedTerminal",
      "module": "uvicorn",
      "args": ["server:app", "--host", "0.0.0.0", "--port", "4000", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend/src"
      },
      "envFile": "${workspaceFolder}/backend/.env",
      "justMyCode": false
    }
  ]
}
