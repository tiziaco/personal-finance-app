# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="FastAPI LangGraph Clerk"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
OPENAI_API_KEY="your-llm-api-key" # e.g. OpenAI API key
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.2

# Clerk Authentication Settings
CLERK_SECRET_KEY="your-clerk-secret-key"
CLERK_ISSUER="https://your-instance.clerk.accounts.dev"
CLERK_OAUTH_CLIENT_ID="your-clerk-oauth-client-id"
CLERK_OAUTH_CLIENT_SECRET="your-clerk-oauth-client-secret"
CLERK_AUTHORIZE_URL="https://your-instance.clerk.accounts.dev/oauth/authorize"
CLERK_TOKEN_URL="https://your-instance.clerk.accounts.dev/oauth/token"

# Database Settings
# For local development: use 'localhost'
# For Docker: docker-compose.yml automatically overrides to 'db'
POSTGRES_HOST=localhost
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT='["1000 per day", "200 per hour"]'
RATE_LIMIT_CHAT='["100 per minute"]'
RATE_LIMIT_CHAT_STREAM='["100 per minute"]'
RATE_LIMIT_MESSAGES='["200 per minute"]'

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
